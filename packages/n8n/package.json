{
  "name": "@relayfile/provider-n8n",
  "version": "0.1.0",
  "description": "Relayfile connection provider for self-hosted n8n instances.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test 'dist/__tests__/*.test.js'"
  },
  "keywords": [
    "relayfile",
    "n8n",
    "provider"
  ],
  "dependencies": {
    "@relayfile/sdk": "^0.1.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
