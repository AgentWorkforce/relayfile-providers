{
  "name": "@relayfile/provider-nango",
  "version": "0.1.0",
  "description": "Nango provider scaffold for Relayfile",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "npm run build && node --test 'dist/__tests__/**/*.test.js'",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "relayfile",
    "nango",
    "provider"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayfile-providers",
    "directory": "packages/nango"
  },
  "dependencies": {
    "@agent-relay/sdk": "^3.2.22",
    "@relayfile/sdk": "^0.1.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
