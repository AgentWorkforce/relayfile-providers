{
  "name": "@relayfile/provider-clerk",
  "version": "0.1.5",
  "description": "Clerk provider for Relayfile",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "npm run build && node --test 'dist/__tests__/**/*.test.js'",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "relayfile",
    "clerk",
    "provider",
    "oauth",
    "webhook"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayfile-providers",
    "directory": "packages/clerk"
  },
  "dependencies": {
    "@relayfile/sdk": "^0.6.0",
    "jose": "^6.2.2",
    "svix": "^1.89.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
