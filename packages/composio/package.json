{
  "name": "@relayfile/provider-composio",
  "version": "0.1.0",
  "description": "Relayfile connection provider for Composio-backed integrations.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --import tsx --test 'src/__tests__/*.test.ts'",
    "prepack": "npm run build"
  },
  "keywords": [
    "relayfile",
    "composio",
    "provider"
  ],
  "dependencies": {
    "@agent-relay/sdk": "^3.2.22",
    "@relayfile/sdk": "file:../../AgentWorkforce-relayfile/packages/sdk/typescript"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
