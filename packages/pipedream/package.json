{
  "name": "@relayfile/provider-pipedream",
  "version": "0.1.5",
  "description": "Pipedream provider for Relayfile with generic provider hooks and Pipedream Connect convenience methods.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "npm run build && node --test 'dist/__tests__/**/*.test.js'",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "relayfile",
    "pipedream",
    "provider",
    "connect"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayfile-providers",
    "directory": "packages/pipedream"
  },
  "dependencies": {
    "@relayfile/sdk": "^0.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
